# Postgres connection string. Get this from your database host
# (e.g. Neon: neon.tech, or Vercel's own Postgres storage integration).
# Use the "pooled" connection string if your host offers one, since serverless
# hosts like Vercel can open many short-lived connections at once.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Admin login password for /admin. Change this to something private.
ADMIN_PASSWORD="change-me-now"

# Random secret used to sign the admin session cookie. Generate your own with:
#   openssl rand -base64 32
SESSION_SECRET=""

# Required for user accounts (signup/login). Generate with: openssl rand -base64 32
USER_SESSION_SECRET=""

# Optional: only needed to sell paid materials via Stripe Checkout.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Optional: set this in production if request headers don't reflect your public URL.
SITE_URL=""

# Optional: only needed for scripts/ship.sh to trigger a redeploy after shipping.
# Get this from your host's dashboard (e.g. Vercel: Project Settings -> Git -> Deploy Hooks).
DEPLOY_HOOK_URL=""

# Optional: only needed for forgot-username/forgot-password emails.
RESEND_API_KEY=""
# Optional: defaults to Resend's shared sandbox sender (only deliverable to your
# own Resend account email until you verify a domain). Set this once you have
# a verified sending domain in Resend.
EMAIL_FROM=""
