DATABASE_URL="file:./dev.db"

# Admin login password for /admin. Change this to something private.
ADMIN_PASSWORD="change-me-now"

# Random secret used to sign the admin session cookie. Generate your own with:
#   openssl rand -base64 32
SESSION_SECRET=""

# Optional: only needed to sell paid materials via Stripe Checkout.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Optional: set this in production if request headers don't reflect your public URL.
SITE_URL=""
